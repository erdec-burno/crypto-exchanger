{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist/out-tsc",
    "tsBuildInfoFile": "dist/out-tsc/tsconfig.app.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  "include": [
    "server.mjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../libs/shared/**/*.ts",
    "../../libs/shared/**/*.tsx",
    "../../libs/web/**/*.ts",
    "../../libs/web/**/*.tsx",
    "../../libs/web/**/*.json"
  ],
  "exclude": [
    "dist",
    "dist/**",
    "../../libs/**/dist",
    "../../libs/**/dist/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../libs/shared/tsconfig.lib.json"
    }
  ]
}
