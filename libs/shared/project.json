{
  "name": "shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/shared",
  "sourceRoot": "libs/shared",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/shared",
        "command": "tsc --build tsconfig.lib.json"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/shared",
        "command": "tsc --build tsconfig.lib.json --emitDeclarationOnly"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/shared",
        "command": "eslint ."
      }
    }
  },
  "tags": ["type:shared"]
}
