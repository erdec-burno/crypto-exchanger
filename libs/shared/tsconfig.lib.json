{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.json"],
  "exclude": [
    "dist",
    "out-tsc",
    "**/*.spec.ts",
    "**/*.test.ts",
    "eslint.config.mjs"
  ]
}
